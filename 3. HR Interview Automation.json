') }}                 </td>               </tr>                <tr>                 <td style=\"padding:10px 0;font-weight:bold;\">                   Duration                 </td>                  <td style=\"padding:10px 0;\">                   Approximately 1 Hour                 </td>               </tr>                <tr>                 <td style=\"padding:10px 0;font-weight:bold;\">                   Platform                 </td>                  <td style=\"padding:10px 0;\">                   Google Meet                 </td>               </tr>                <tr>                 <td style=\"padding:10px 0;font-weight:bold;\">                   Date & Time                 </td>                  <td style=\"padding:10px 0;\">                   {{                    new Date($('Save Data').item.json.start.dateTime).toLocaleString('en-IN', {                     dateStyle: 'full',                     timeStyle: 'short'                   })                    }}                    <br><br>                    to                    <br><br>                    {{                    new Date($('Save Data').item.json.end.dateTime).toLocaleTimeString('en-IN', {                     timeStyle: 'short'                   })                    }}                 </td>               </tr>                <!-- Button -->               <tr>                 <td colspan=\"2\" align=\"center\" style=\"padding-top:30px;\">                    <a                      href=\"{{ $('Save Data').item.json.conferenceData.entryPoints[0].uri }}\"                     style=\"                       background-color:#0f766e;                       color:white;                       text-decoration:none;                       padding:14px 30px;                       border-radius:8px;                       display:inline-block;                       font-weight:bold;                       font-size:15px;                     \"                   >                     Join Google Meet                   </a>                  </td>               </tr>              </table>              <!-- Paragraphs -->             <p style=\"font-size:15px;margin-top:25px;\">               Please ensure you join the meeting a few minutes before the scheduled time. Kindly review the candidate profile and relevant interview notes beforehand.             </p>              <p style=\"font-size:15px;\">               In case of any scheduling conflicts or technical issues, please coordinate with the recruitment team.             </p>              <p style=\"font-size:15px;\">               Thank you for your participation in the recruitment process.             </p>              <!-- Signature -->             <p style=\"margin-top:35px;margin-bottom:0;\">               Best Regards,             </p>              <p style=\"margin-top:6px;font-weight:bold;color:#0f766e;font-size:16px;\">               HR Recruitment Team             </p>            </td>         </tr>          <!-- Footer -->         <tr>           <td align=\"center\" style=\"background:#ecfeff;padding:16px;font-size:13px;color:#64748b;\">             Automated recruiter interview notification           </td>         </tr>        </table>      </td>   </tr> </table>",
