        "message": "=<div style=\"background-color:#f4f7fb;padding:40px 20px;font-family:Arial,sans-serif;\">\n  \n  <div style=\"max-width:650px;margin:auto;background:#ffffff;border-radius:16px;overflow:hidden;box-shadow:0 4px 15px rgba(0,0,0,0.08);\">\n    \n    <!-- Header -->\n    <div style=\"background:linear-gradient(135deg,#2563eb,#1e40af);padding:30px;text-align:center;color:white;\">\n      <h1 style=\"margin:0;font-size:28px;\">Interview Scheduled</h1>\n      <p style=\"margin-top:10px;font-size:15px;opacity:0.9;\">\n        Your interview has been successfully confirmed\n      </p>\n    </div>\n\n    <!-- Body -->\n    <div style=\"padding:35px;color:#333333;line-height:1.7;\">\n\n      <p style=\"font-size:16px;\">\n        Dear \n        <strong style=\"color:#2563eb;\">\n          {{ $json.summary.replace('Interview with ', '') }}\n        </strong>,\n      </p>\n\n      <p style=\"font-size:15px;\">\n        We are pleased to inform you that your interview has been successfully scheduled. Please find the details below.\n      </p>\n\n      <!-- Details Card -->\n      <div style=\"background:#f8fafc;border:1px solid #e2e8f0;border-radius:12px;padding:25px;margin:25px 0;\">\n\n        <h2 style=\"margin-top:0;color:#1e40af;font-size:20px;\">\n          Interview Details\n        </h2>\n\n        <table style=\"width:100%;border-collapse:collapse;font-size:15px;\">\n          \n          <tr>\n            <td style=\"padding:10px 0;font-weight:bold;width:160px;\">Duration</td>\n            <td>Approximately 1 Hour</td>\n          </tr>\n\n          <tr>\n            <td style=\"padding:10px 0;font-weight:bold;\">Platform</td>\n            <td>Google Meet</td>\n          </tr>\n\n          <tr>\n            <td style=\"padding:10px 0;font-weight:bold;\">Date & Time</td>\n            <td>\n              {{ \n              new Date($json.start.dateTime).toLocaleString('en-IN', {\n                dateStyle: 'full',\n                timeStyle: 'short'\n              }) \n              }}\n              <br>\n              to\n              {{ \n              new Date($json.end.dateTime).toLocaleTimeString('en-IN', {\n                timeStyle: 'short'\n              }) \n              }}\n            </td>\n          </tr>\n\n        </table>\n\n        <!-- Meet Button -->\n        <div style=\"text-align:center;margin-top:30px;\">\n          <a \n            href=\"{{ $json.conferenceData.entryPoints[0].uri }}\"\n            style=\"\n              background:linear-gradient(135deg,#2563eb,#1d4ed8);\n              color:white;\n              text-decoration:none;\n              padding:14px 28px;\n              border-radius:10px;\n              font-weight:bold;\n              display:inline-block;\n              font-size:15px;\n            \"\n          >\n            Join Google Meet\n          </a>\n        </div>\n\n      </div>\n\n      <p style=\"font-size:15px;\">\n        Please join the meeting a few minutes before the scheduled time and ensure that your internet connection, microphone, and camera are functioning properly.\n      </p>\n\n      <p style=\"font-size:15px;\">\n        If you face any issues joining the meeting, kindly contact the HR team or reply to this email.\n      </p>\n\n      <p style=\"font-size:15px;\">\n        We look forward to the interaction.\n      </p>\n\n      <br>\n\n      <p style=\"margin-bottom:0;\">\n        Best Regards,\n      </p>\n\n      <p style=\"margin-top:5px;font-weight:bold;color:#1e40af;font-size:16px;\">\n        HR Recruitment Team\n      </p>\n\n    </div>\n\n    <!-- Footer -->\n    <div style=\"background:#eff6ff;padding:18px;text-align:center;font-size:13px;color:#64748b;\">\n      This is an automated interview scheduling email.\n    </div>\n\n  </div>\n\n</div>",
